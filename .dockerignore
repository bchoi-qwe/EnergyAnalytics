# --- Compiled Objects (CRITICAL for Mac users) ---
src/*.o
src/*.so
src/*.dll
src/*.dylib
src/*.d
src/*.gcda
src/*.gcno
src/symbols.rds
src/Makedeps
src-i386/
src-x64/

# --- Git & CI ---
.git/
.github/
.gitignore
.Rbuildignore
.gitattributes

# --- IDE & Metadata ---
.Rproj.user/
.Rhistory
.RData
.RDataTmp
.RData.*
.DS_Store
**/.DS_Store
*.Rproj

# --- Project-Specific ---
.agents/
.claude/
.playwright-cli/
notes/
specs/
docs/
artifacts/
UI_MINIMUM_SPECS.md
README.md
