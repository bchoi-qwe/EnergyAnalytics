data-raw/

# --- Local Config & Secrets ---
.Renviron
.Renviron.local
.Rprofile
.env
.env.*

# --- Package Management ---
renv/
renv.lock
node_modules/
__pycache__/

# --- Tests ---
# Exclude tests from the production image to keep it lean.
tests/
testthat.R
