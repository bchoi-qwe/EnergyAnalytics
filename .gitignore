*-Ex.R
/*.tar.gz
/*.Rcheck/
vignettes/*.html
vignettes/*.pdf
**/*_cache/
**/cache/
*.utf8.md
*.knit.md

# --- Compiled Objects (Rcpp/C++) ---
src/*.o
src/*.so
src/*.dll
src/*.dylib
src/*.d
src/*.gcda
src/*.gcno
src/symbols.rds
src/Makedeps
src-i386/
src-x64/

# --- IDE & System Files ---
.Rproj.user/
.DS_Store
**/.DS_Store
**/Thumbs.db
.idea/
**/*.swp
**/*.swo
.vscode/

# --- Environment & Secrets ---
.Renviron
.Renviron.local
.env
.env.*
.httr-oauth

# --- Package Management ---
renv/library/
renv/local/
renv/python/
renv/staging/
.python-version
__pycache__/
node_modules/

